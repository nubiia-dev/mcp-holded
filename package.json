{
  "name": "@nubiia/mcp-holded",
  "mcpName": "io.github.nubiia-dev/mcp-holded",
  "version": "1.7.0",
  "description": "MCP server for the Holded API: invoicing, accounting, contacts, products & banking for AI assistants like Claude. Built by Nubiia.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-holded": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "prepare": "husky",
    "prepublishOnly": "npm run clean && npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "holded",
    "holded-api",
    "invoice",
    "invoicing",
    "accounting",
    "facturacion",
    "contacts",
    "banking",
    "erp",
    "api",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "automation",
    "nubiia"
  ],
  "author": {
    "name": "Nubiia",
    "email": "hola@nubiia.es",
    "url": "https://nubiia.es"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nubiia-dev/mcp-holded.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^26.0.1",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.9.3",
    "semantic-release": "^25.0.5",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://nubiia.es"
}
